# ── Turso (libSQL) — set by the Vercel Turso integration automatically ─────────
# These are added by Vercel when you connect Turso via the Marketplace.
# For local dev, copy the values from your Turso dashboard or run:
#   vercel env add thermometer_TURSO_DATABASE_URL development
#   vercel env add thermometer_TURSO_AUTH_TOKEN development
thermometer_TURSO_DATABASE_URL=libsql://your-db-name.turso.io
thermometer_TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Google OAuth 2.0 (from Google Cloud Console) ──────────────────────────────
# Follow GOOGLE_CLOUD_SETUP.md to obtain these values.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# ── JWT session signing secret (generate with: openssl rand -base64 32) ───────
JWT_SECRET=replace-with-at-least-32-random-characters

# ── Base URL (for OAuth redirect URI) ─────────────────────────────────────────
# In production Vercel sets the host automatically; set this for local dev.
APP_BASE_URL=http://localhost:3000
